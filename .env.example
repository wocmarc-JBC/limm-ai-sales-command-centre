NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_APP_ENV=local

# Development-only review route. Keep false/empty for production.
NEXT_PUBLIC_ENABLE_REVIEW_ROUTE=false

# Server/script-only future value. Never import this into frontend/client code.
SUPABASE_SERVICE_ROLE_KEY=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BRAIN_DRY_RUN=false

# WhatsApp Cloud API controls.
# Default is safe: inbound disabled, auto-reply disabled, public auto-reply disabled.
# Marcus-approved live mode requires LIVE_INBOUND=true, TEST_AUTO_REPLY=true,
# PUBLIC_AUTO_REPLY=true, and TEST_MODE=false in deployment env vars.
WHATSAPP_LIVE_INBOUND_ENABLED=false
WHATSAPP_TEST_AUTO_REPLY_ENABLED=false
WHATSAPP_PUBLIC_AUTO_REPLY_ENABLED=false
WHATSAPP_TEST_MODE=true
WHATSAPP_DEBUG_ENDPOINT_ENABLED=false
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_BUSINESS_NUMBER=
WHATSAPP_GRAPH_VERSION=v21.0

CALENDAR_PROVIDER=mock

# Optional for scripts/verify_live_authenticated_actions.mjs only.
SUPABASE_TEST_EMAIL=
SUPABASE_TEST_PASSWORD=
