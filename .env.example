NEXT_PUBLIC_SUPABASE_URL=
# Preferred modern client key. The legacy anon key remains a compatibility fallback.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_APP_ENV=local
NEXT_PUBLIC_LIMM_INSTAGRAM_URL=https://www.instagram.com/limmworks/

# Development-only review route. Keep false/empty for production.
NEXT_PUBLIC_ENABLE_REVIEW_ROUTE=false

# Server/script-only future value. Never import this into frontend/client code.
# Preferred modern server key. Keep both values server-only.
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BRAIN_DRY_RUN=false
OPENAI_WHATSAPP_REPLY_ENABLED=false
OPENAI_WHATSAPP_MODEL=gpt-4.1-mini
WHATSAPP_REPLY_BRAIN_DEBUG=false
WHATSAPP_AI_SALES_BRAIN_ENABLED=false
WHATSAPP_AI_DRAFT_REPLY_ENABLED=false
WHATSAPP_AI_PROVIDER=openai
V6_ULTIMATE_QA_CENTRE_ENABLED=true
LEAD_HARD_DELETE_ENABLED=true
BOT_PAUSE_DEFAULT_MODE=manual
LEAD_SCORING_ENABLED=true
WEEKLY_BOSS_REPORT_DRAFT_ENABLED=true
GOLD_COMMAND_CENTRE_UI_ENABLED=true

# WhatsApp Cloud API controls.
# Default is safe: inbound disabled, auto-reply disabled, public auto-reply disabled.
# Marcus-approved live mode requires LIVE_INBOUND=true, TEST_AUTO_REPLY=true,
# PUBLIC_AUTO_REPLY=true, and TEST_MODE=false in deployment env vars.
WHATSAPP_LIVE_INBOUND_ENABLED=false
WHATSAPP_TEST_AUTO_REPLY_ENABLED=false
WHATSAPP_PUBLIC_AUTO_REPLY_ENABLED=false
WHATSAPP_TEST_MODE=true
WHATSAPP_DEBUG_ENDPOINT_ENABLED=false
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_BUSINESS_NUMBER=
WHATSAPP_GRAPH_VERSION=v21.0
LIMM_INSTAGRAM_URL=https://www.instagram.com/limmworks/

# Optional server-only human handoff alerts for important WhatsApp leads.
# If enabled without a provider key, the app logs a safe skipped-handoff trace.
HANDOFF_EMAIL_ENABLED=false
HANDOFF_EMAIL_TO=limmwork@gmail.com
HANDOFF_EMAIL_FROM=
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=

CALENDAR_PROVIDER=mock
CALENDAR_BOOKING_ENABLED=false
CALENDAR_BOSS_APPROVAL_REQUIRED=true
CALENDAR_AUTO_BOOKING_ENABLED=false
GOOGLE_CALENDAR_CONNECTED=false
GOOGLE_CALENDAR_ID=
GOOGLE_CALENDAR_TIMEZONE=Asia/Singapore

# Optional for scripts/verify_live_authenticated_actions.mjs only.
SUPABASE_TEST_EMAIL=
SUPABASE_TEST_PASSWORD=
